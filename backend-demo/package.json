{
  "name": "gaussian-backend-demo",
  "version": "0.1.0",
  "private": true,
  "description": "高斯建图项目后端 Demo",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "db:seed": "tsx scripts/seed.ts",
